{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["ARG PYTHON_3_11_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "python-3.11",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "python/cpython",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["ARG PYTHON_3_12_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "python-3.12",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "python/cpython",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["ARG PYTHON_3_13_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "python-3.13",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "python/cpython",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Containerfile$"],
      "matchStrings": ["ARG PYTHON_3_14_VERSION=(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "python-3.14",
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "python/cpython",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["debian"],
      "enabled": false
    },
    {
      "matchDepNames": ["python-3.11"],
      "allowedVersions": ">=3.11.0 <3.12.0"
    },
    {
      "matchDepNames": ["python-3.12"],
      "allowedVersions": ">=3.12.0 <3.13.0"
    },
    {
      "matchDepNames": ["python-3.13"],
      "allowedVersions": ">=3.13.0 <3.14.0"
    },
    {
      "matchDepNames": ["python-3.14"],
      "allowedVersions": ">=3.14.0 <3.15.0"
    }
  ]
}
